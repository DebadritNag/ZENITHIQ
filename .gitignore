# ─────────────────────────────────────────────
# Zenith IQ — .gitignore
# ─────────────────────────────────────────────

# Environment — NEVER commit real keys
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environment
venv/
.venv/
env/
ENV/

# HuggingFace model cache (large files)
.cache/
models/cache/
*.safetensors
*.bin
*.pt
*.ckpt

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.env
frontend/.env.local

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Supabase local dev
supabase/.branches/
supabase/.temp/
