# ─────────────────────────────────────────────
# Zenith IQ — Environment Variables
# Copy this file to .env and fill in your keys
# cp .env.example .env
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key   # needed for write operations

# ── Google Gemini ─────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── HuggingFace ───────────────────────────────
# Get from: https://huggingface.co/settings/tokens
# Required to download cardiffnlp/twitter-roberta-base-sentiment-latest
HUGGINGFACE_TOKEN=your_huggingface_token

# ── News API ──────────────────────────────────
# Get from: https://newsapi.org/register
# Optional — falls back to free scrapers (Yahoo RSS, Finviz) if not set
NEWS_API_KEY=your_newsapi_key

# ── App ───────────────────────────────────────
APP_ENV=development          # development | production
APP_HOST=127.0.0.1           # use 0.0.0.0 to expose on network
APP_PORT=8000
